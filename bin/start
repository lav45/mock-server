#!/usr/bin/env php
<?php declare(strict_types=1);

require __DIR__ . '/../vendor/autoload.php';

use Amp\Cluster\Cluster;
use Amp\Http\Server\Driver\SocketClientFactory;
use Amp\Http\Server\SocketHttpServer;
use Amp\Socket;
use Faker\Factory as FakerFactory;
use Lav45\MockServer\Bootstrap\Config;
use Lav45\MockServer\Bootstrap\ErrorHandler;
use Lav45\MockServer\Bootstrap\LoggerFactory;
use Lav45\MockServer\Bootstrap\RouterRequestHandler;
use Lav45\MockServer\Domain\Mock\Response\ContentResponse;
use Lav45\MockServer\Domain\Mock\Response\ProxyResponse;
use Lav45\MockServer\Http\DelayHandler;
use Lav45\MockServer\Http\MockRequestHandler;
use Lav45\MockServer\Parser\ParserFactory;
use Lav45\MockServer\Responder\ContentResponder;
use Lav45\MockServer\Responder\HttpClient\Factory as HttpClientFactory;
use Lav45\MockServer\Responder\ProxyResponder;
use Lav45\MockServer\Responder\ResponseFactory;
use Lav45\MockServer\Responder\WebHookHandler;
use Lav45\MockServer\Router\DispatcherFactory;
use Lav45\MockServer\Router\MockFactory;
use Lav45\MockServer\Router\MockFactory\CollectionFactory;
use Lav45\MockServer\Router\MockFactory\ContentFactory;
use Lav45\MockServer\Router\MockFactory\ProxyFactory;
use Lav45\MockServer\Router\MockFactory\RequestParserContext;
use Lav45\MockServer\Router\MockFactory\ResponseFactoryResolver;
use Lav45\MockServer\Router\MockFactory\WebHooksFactory;
use Lav45\MockServer\Router\Watcher\FileStorage;
use Lav45\MockServer\Router\Watcher\Watcher;
use Lav45\Watcher\Listener;
use Lav45\Watcher\Watcher as FileWatcher;

(static function (): void {

    $config = new Config()
        ->port(getenv('PORT'))
        ->mocks(getenv('MOCKS_PATH'))
        ->locale(getenv('LOCALE'))
        ->log(getenv('LOG_LEVEL'))
        ->fileWatch(getenv('FILE_WATCH_TIMEOUT'));

    $logHandler = Cluster::isWorker() ? Cluster::createLogHandler($config->getLogLevel()) : null;
    $logName = 'mock-server-' . (Cluster::getContextId() ?? getmypid());
    $logger = new LoggerFactory($logName, $config->getLogLevel())->create($logHandler);

    $faker = FakerFactory::create($config->getLocale());
    $parser = new ParserFactory($faker)->create();
    $httpClient = new HttpClientFactory($logger)->create();

    $mockFactory = new MockFactory(
        parserContext: new RequestParserContext($parser),
        webHooksFactory: new WebHooksFactory(),
        responseFactoryResolver: new ResponseFactoryResolver([
            ContentFactory::TYPE => new ContentFactory(),
            ProxyFactory::TYPE => new ProxyFactory(),
            CollectionFactory::TYPE => new CollectionFactory(),
        ]),
    );
    $webHookHandler = new WebHookHandler($httpClient->withLabel('WebHook'), $logger);
    $responseFactory = new ResponseFactory([
        ProxyResponse::class => new ProxyResponder($httpClient->withLabel('Proxy')),
        ContentResponse::class => new ContentResponder(),
    ]);
    $delayHandler = new DelayHandler();

    $requestFactory = new MockRequestHandler(
        webHookHandler: $webHookHandler,
        responseFactory: $responseFactory,
        mockFactory: $mockFactory,
        delayHandler: $delayHandler,
    );

    $watchDir = $config->getMocksPath();
    $watcher = new Watcher(
        dispatcherFactory: new DispatcherFactory($requestFactory, $logger),
        watchDir: $watchDir,
        fileStorage: new FileStorage($watchDir, $logger),
        logger: $logger,
    );

    if (Cluster::isWorker() === false) {
        Amp\async(
            static fn() => $watcher->run(
                watcher: new FileWatcher(new Listener()),
                delay: $config->getFileWatchTimeout(),
            ),
        );
    }

    $errorHandler = new ErrorHandler();
    $reactor = new RouterRequestHandler($errorHandler, $watcher);

    $serverSocketFactory = Cluster::getServerSocketFactory();
    $clientFactory = new SocketClientFactory($logger);
    $server = new SocketHttpServer($logger, $serverSocketFactory, $clientFactory);
    $server->expose(new Socket\InternetAddress('0.0.0.0', $config->getPort()));
    $server->start($reactor, $errorHandler);

    Cluster::awaitTermination();

    $server->stop();

})();
