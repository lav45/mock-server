#!/usr/bin/env php
<?php declare(strict_types=1);

require __DIR__ . '/../vendor/autoload.php';

use Lav45\MockServer\Bootstrap\ReactorFactory;
use Lav45\MockServer\Driver\Config;
use Lav45\MockServer\Driver\HttpClientFactory;
use Lav45\MockServer\Driver\LoggerFactory;
use Lav45\MockServer\Driver\Server;
use Lav45\MockServer\Driver\WebHookQueue;
use Lav45\MockServer\Extension\WebHook\WebHookHandler;

(static function (): void {

    $configFile = getenv('CONFIG_PATH') ?: '/app/etc/config.yaml';
    $config = Config::fromFile($configFile)
        ->port(getenv('PORT'))
        ->mocks(getenv('MOCKS_PATH'))
        ->locale(getenv('LOCALE'))
        ->log(getenv('LOG_LEVEL'))
        ->filterHeaders(getenv('FILTER_HEADERS'))
        ->maxBufferSize(getenv('MAX_BUFFER_SIZE'));

    $logger = new LoggerFactory('mock-server', $config->getLogLevel())->create();
    $httpClient = new HttpClientFactory($logger, maxBufferSize: $config->getMaxBufferSize())->create();

    $webHookQueue = new WebHookQueue(
        new WebHookHandler(
            httpClient: $httpClient->withLabel('WebHook'),
            logger: $logger,
        ),
    );

    $reactor = new ReactorFactory(
        mocksPath: $config->getMocksPath(),
        locale: $config->getLocale(),
        filterHeaders: $config->getFilterHeaders(),
        httpClient: $httpClient,
        webHookQueue: $webHookQueue,
        logger: $logger,
        extensions: $config->getExtensions(),
        schema: $config->getSchema(),
        env: $config->getEnv(),
    )->create();

    $server = new Server($logger);
    $server->expose('0.0.0.0', $config->getPort());

    if ($tls = $config->getTls()) {
        $server->exposeTls('0.0.0.0', $tls);
    }

    $server->run($reactor);

})();
