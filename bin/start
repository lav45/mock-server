#!/usr/bin/env php
<?php declare(strict_types=1);

require __DIR__ . '/../vendor/autoload.php';

use Amp\Cluster\Cluster;
use Amp\Http\Server\Driver\SocketClientFactory;
use Amp\Http\Server\RequestHandler\ClosureRequestHandler;
use Amp\Http\Server\SocketHttpServer;
use Amp\Socket;
use Faker\Factory as FakerFactory;
use Lav45\MockServer\Bootstrap\Config;
use Lav45\MockServer\Bootstrap\DispatcherFactory;
use Lav45\MockServer\Bootstrap\ErrorHandler;
use Lav45\MockServer\Bootstrap\LoggerFactory;
use Lav45\MockServer\Bootstrap\RouterRequestHandler;
use Lav45\MockServer\Bootstrap\Watcher\FileStorage;
use Lav45\MockServer\Bootstrap\Watcher\Watcher;
use Lav45\MockServer\DataFactory\CollectionFactory;
use Lav45\MockServer\DataFactory\ContentFactory;
use Lav45\MockServer\DataFactory\ProxyFactory;
use Lav45\MockServer\DataFactory\RequestParserContext;
use Lav45\MockServer\DataFactory\WebHooksFactory;
use Lav45\MockServer\Middleware\CollectionMiddleware;
use Lav45\MockServer\Middleware\ContentMiddleware;
use Lav45\MockServer\Middleware\FallbackMiddleware;
use Lav45\MockServer\Middleware\ParserMiddleware;
use Lav45\MockServer\Middleware\Pipeline;
use Lav45\MockServer\Middleware\ProxyMiddleware;
use Lav45\MockServer\Middleware\ResponseTypeMiddleware;
use Lav45\MockServer\Middleware\ThrottlingMiddleware;
use Lav45\MockServer\Middleware\WebHookMiddleware;
use Lav45\MockServer\Parser\DateParse;
use Lav45\MockServer\Parser\EnvParser;
use Lav45\MockServer\Parser\FakerParser;
use Lav45\MockServer\Parser\ParamParser;
use Lav45\MockServer\Responder\ContentResponder;
use Lav45\MockServer\Responder\HttpClient\Factory as HttpClientFactory;
use Lav45\MockServer\Responder\ProxyResponder;
use Lav45\MockServer\Responder\WebHookHandler;
use Lav45\Watcher\Listener;
use Lav45\Watcher\Watcher as FileWatcher;

(static function (): void {

    $config = new Config()
        ->port(getenv('PORT'))
        ->mocks(getenv('MOCKS_PATH'))
        ->locale(getenv('LOCALE'))
        ->log(getenv('LOG_LEVEL'))
        ->fileWatch(getenv('FILE_WATCH_TIMEOUT'));

    $logHandler = Cluster::isWorker() ? Cluster::createLogHandler($config->getLogLevel()) : null;
    $logName = 'mock-server-' . (Cluster::getContextId() ?? getmypid());
    $logger = new LoggerFactory($logName, $config->getLogLevel())->create($logHandler);

    $faker = FakerFactory::create($config->getLocale());
    $parser = new ParamParser(
        new DateParse(
            new EnvParser(
                new FakerParser($faker),
            ),
        ),
    );

    $httpClient = new HttpClientFactory($logger)->create();

    $requestHandler = new ClosureRequestHandler(
        Pipeline::create(
            new ParserMiddleware(
                new RequestParserContext($parser),
            ),
            new ResponseTypeMiddleware(ContentFactory::TYPE),
            new WebHookMiddleware(
                factory: new WebHooksFactory(),
                handler: new WebHookHandler(
                    httpClient: $httpClient->withLabel('WebHook'),
                    logger: $logger,
                ),
            ),
            new ThrottlingMiddleware(),
            new ContentMiddleware(
                factory: new ContentFactory(),
                responder: new ContentResponder(),
            ),
            new ProxyMiddleware(
                factory: new ProxyFactory(),
                responder: new ProxyResponder(
                    httpClient: $httpClient->withLabel('Proxy'),
                ),
            ),
            new CollectionMiddleware(
                factory: new CollectionFactory(),
                responder: new ContentResponder(),
            ),
            new FallbackMiddleware($logger),
        ),
    );

    $watchDir = $config->getMocksPath();
    $watcher = new Watcher(
        dispatcherFactory: new DispatcherFactory($logger),
        watchDir: $watchDir,
        fileStorage: new FileStorage($watchDir, $logger),
        logger: $logger,
    );

    if (Cluster::isWorker() === false) {
        Amp\async(
            static fn() => $watcher->run(
                watcher: new FileWatcher(new Listener()),
                delay: $config->getFileWatchTimeout(),
            ),
        );
    }

    $errorHandler = new ErrorHandler();
    $reactor = new RouterRequestHandler(
        errorHandler: $errorHandler,
        watcher: $watcher,
        handler: $requestHandler,
    );

    $serverSocketFactory = Cluster::getServerSocketFactory();
    $clientFactory = new SocketClientFactory($logger);
    $server = new SocketHttpServer($logger, $serverSocketFactory, $clientFactory);
    $server->expose(new Socket\InternetAddress('0.0.0.0', $config->getPort()));
    $server->start($reactor, $errorHandler);

    Cluster::awaitTermination();

    $server->stop();

})();
