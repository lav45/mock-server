#!/usr/bin/env php
<?php declare(strict_types=1);

require __DIR__ . '/../vendor/autoload.php';

use Amp\Http\Server\Driver\SocketClientFactory;
use Amp\Http\Server\SocketHttpServer;
use Amp\Socket;
use Faker\Factory as FakerFactory;
use Lav45\MockServer\Config;
use Lav45\MockServer\DispatcherFactory;
use Lav45\MockServer\ErrorHandler;
use Lav45\MockServer\FileStorage;
use Lav45\MockServer\Infrastructure\HttpClient\Factory as HttpClientFactory;
use Lav45\MockServer\Infrastructure\Parser\ParserFactory;
use Lav45\MockServer\LoggerFactory;
use Lav45\MockServer\Reactor;
use Lav45\MockServer\RequestFactory;
use Lav45\MockServer\Watcher\Watcher;
use Lav45\Watcher\Listener;
use Lav45\Watcher\Watcher as FileWatcher;

(static function (): void {

    $config = new Config()
        ->port(getenv('PORT'))
        ->mocks(getenv('MOCKS_PATH'))
        ->locale(getenv('LOCALE'))
        ->log(getenv('LOG_LEVEL'))
        ->fileWatch(getenv('FILE_WATCH_TIMEOUT'));

    $logger = LoggerFactory::create('mock-server', $config->getLogLevel());

    $parserFactory = new ParserFactory(
        FakerFactory::create($config->getLocale()),
    );
    $httpClient = new HttpClientFactory($logger)->create();
    $requestFactory = new RequestFactory($parserFactory, $httpClient, $logger);
    $dispatcherFactory = new DispatcherFactory($requestFactory, $logger);

    $watchDir = $config->getMocksPath();
    $fileStorage = new FileStorage($watchDir, $logger);
    $watcher = new Watcher(
        dispatcherFactory: $dispatcherFactory,
        watchDir: $watchDir,
        fileStorage: $fileStorage,
        logger: $logger,
    );

    if ($timeout = $config->getFileWatchTimeout()) {
        Amp\async(
            static fn() => $watcher->run(
                watcher: new FileWatcher(new Listener()),
                delay: $timeout,
            ),
        );
    }

    $errorHandler = new ErrorHandler();
    $reactor = new Reactor($errorHandler, $watcher);

    $serverSocketFactory = new Socket\ResourceServerSocketFactory();
    $clientFactory = new SocketClientFactory($logger);
    $server = new SocketHttpServer($logger, $serverSocketFactory, $clientFactory);
    $server->expose(new Socket\InternetAddress('0.0.0.0', $config->getPort()));
    $server->start($reactor, $errorHandler);

    $logger->info(\sprintf("Received signal %d, stopping HTTP server", Amp\trapSignal([SIGINT, SIGTERM])));

    $server->stop();

})();