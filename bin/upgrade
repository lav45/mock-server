#!/usr/bin/env php
<?php declare(strict_types=1);

namespace Lav45\MockServer\Bin;

use Lav45\MockServer\Bootstrap\FileSystem;
use Lav45\MockServer\Bootstrap\MockStorage;

require __DIR__ . '/../vendor/autoload.php';

$mocksPath = \getenv('MOCKS_PATH') ?: '/app/mocks';
$mocksPath = \rtrim($mocksPath, '/');

$migratePath = __DIR__ . '/../migrates';

// ----------------------------------------------------------------------------

$migrateList = FileSystem::getFileList($migratePath, static function (string $path): bool {
    return \str_ends_with(\basename($path), '.php');
});
$migrates = [];
foreach ($migrateList as $file) {
    $migrates[] = include $file;
}

$mocksList = new MockStorage($mocksPath)->getFiles();
foreach ($mocksList as $path => $data) {
    $result = [];
    foreach ($data as $item) {
        foreach ($migrates as $migrate) {
            $item = $migrate($item);
        }
        $result[] = $item;
    }
    if ($data !== $result) {
        $content = \json_encode($result, JSON_PRETTY_PRINT | JSON_UNESCAPED_UNICODE | JSON_UNESCAPED_SLASHES | JSON_THROW_ON_ERROR);
        \file_put_contents($path, $content);
        echo '.';
    }
}

echo "\n";
