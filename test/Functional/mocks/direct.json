[
    {
        "version": 8,
        "env": {
            "webhook": {
                "url": "{env.WEBHOOK_STORAGE_URL}/storage"
            },
            "uuid": "{{faker.uuid}}"
        },
        "request": {
            "method": "PUT",
            "path": "/direct/{id:\\d+}"
        },
        "direct": {
            "url": "http://127.0.0.1:{env.PORT}/direct/data",
            "headers": {
                "x-status": "active"
            }
        }
    },
    {
        "version": 8,
        "request": {
            "method": "PUT",
            "path": "/direct/data"
        },
        "response": {
            "type": "content",
            "body": {
                "response": {
                    "type": "content",
                    "headers": {
                        "x-status": "open"
                    },
                    "json": {
                        "mainParams": "\\{\\{request.params\\}\\}",
                        "directParams": "{{request.params}}",
                        "directGet": "{{request.query}}",
                        "directPost": "{{request.post}}",
                        "directHeaders": "{{request.headers}}"
                    }
                },
                "webhooks": [
                    {
                        "url": "{{env.webhook.url}}"
                    },
                    {
                        "method": "PUT",
                        "url": "{{env.webhook.url}}",
                        "json": {
                            "id": "{{faker.uuid}}",
                            "name": "{{faker.name}}"
                        }
                    }
                ]
            },
            "headers": {
                "content-type": "application/json"
            }
        }
    }
]