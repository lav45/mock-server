[
    {
        "version": 8,
        "request": {
            "path": "/response/content/json"
        },
        "env": {
            "uuid": "{{faker.uuid}}",
            "value": 1.2
        },
        "response": {
            "type": "content",
            "body": {
                "id": "{env.uuid}/{faker.uuid}",
                "domain": "{{env.DOMAIN}}",
                "url": "https://{env.DOMAIN}/v1",
                "value": "{{env.value}}"
            },
            "headers": {
                "content-type": "application/json"
            }
        }
    }
]